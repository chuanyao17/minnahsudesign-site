---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectGallery from '../../components/ProjectGallery.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects', ({ data }) => !data.draft);
  return projects.map((project) => {
    const resolvedSlug = project.data.slug ?? project.id;
    return {
      params: { slug: resolvedSlug },
      props: { project },
    };
  });
}

const { project } = Astro.props;
const { Content } = await render(project);
const cover = project.data.coverImage;
---
<BaseLayout title={project.data.title} description={project.data.description}>
  <main class="max-w-[1600px] mx-auto px-6 md:px-12 lg:px-24">
    
    <!-- Cinematic Cover -->
    {cover && (
      <section class="w-full h-[60vh] md:h-[80vh] min-h-[500px] mb-16 md:mb-24">
        <Image 
          src={cover} 
          alt={project.data.title} 
          class="w-full h-full object-cover bg-text-muted/10"
          loading="eager"
          fetchpriority="high"
        />
      </section>
    )}

    <!-- Editorial Header & Metadata Grid -->
    <header class="grid grid-cols-1 md:grid-cols-12 gap-12 md:gap-8 mb-24 md:mb-32">
      <!-- Left Column: Metadata -->
      <div class="md:col-span-4 lg:col-span-3">
        <dl class="text-xs text-text-muted uppercase tracking-widest space-y-8">
          <div>
            <dt class="mb-2 opacity-60">Project</dt>
            <dd class="text-text-base">{project.data.title}</dd>
          </div>
          {project.data.publishedAt && (
            <div>
              <dt class="mb-2 opacity-60">Date</dt>
              <dd class="text-text-base">{new Date(project.data.publishedAt).toLocaleDateString('en-US', { year: 'numeric', month: 'long' })}</dd>
            </div>
          )}
        </dl>
      </div>

      <!-- Right Column: Title & Prose -->
      <div class="md:col-span-8 lg:col-span-9">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-sans tracking-tight leading-tight mb-16 max-w-4xl">
          {project.data.title}
        </h1>
        
        <!-- Markdown Prose Styling via Arbitrary Variants -->
        <article class="[&>p]:text-base md:[&>p]:text-lg [&>p]:leading-relaxed [&>p]:mb-10 [&>p]:max-w-3xl [&>p]:text-text-muted [&>h2]:text-2xl [&>h2]:tracking-tight [&>h2]:mb-6 [&>h2]:mt-16 [&>h3]:text-xl [&>h3]:tracking-tight [&>h3]:mb-4 [&>h3]:mt-12 [&>ul]:list-disc [&>ul]:pl-6 [&>ul]:mb-8 [&>ul]:text-text-muted [&>img]:w-full [&>img]:my-16">
          <Content />
        </article>
      </div>
    </header>

    <!-- Project Gallery -->
    <ProjectGallery gallery={project.data.gallery} />

    <!-- Footer Navigation (Pacing) -->
    <nav class="py-32 flex justify-center border-t border-text-muted/10 mt-32">
      <a href="/projects/" class="text-sm uppercase tracking-widest text-text-muted hover:text-text-base transition-colors duration-500">
        Back to Projects
      </a>
    </nav>

  </main>
</BaseLayout>
