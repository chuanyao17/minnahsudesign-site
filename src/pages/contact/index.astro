---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Footer from "../../components/Footer.astro";

// Native form POST (no client JS) to Web3Forms, which emails each
// submission to the studio. The access key is a public form id (safe
// to expose in client-side code per Web3Forms).
const FORM_ACTION = "https://api.web3forms.com/submit";
const ACCESS_KEY = "c55d54dc-dac9-4537-ae13-16ed58aae4fe";

// Absolute URL to our branded thank-you page. Resolved against the current
// origin, so it points at localhost during dev and the production domain
// once deployed. Web3Forms 302-redirects here after a successful submit.
const REDIRECT_URL = new URL("/contact/thank-you/", Astro.url).href;

const inputClass =
  "w-full bg-transparent border-0 border-b border-brand-sage/40 pb-3 " +
  "text-lg font-light text-text-base placeholder:text-text-muted/50 " +
  "focus:outline-none focus:border-brand-sage transition-colors duration-300";
---
<BaseLayout
  title="Contact | Minna Hsu Design"
  description="Get in touch with Minna Hsu Design Studio for interior and architectural design enquiries."
>
  <main class="px-6 md:px-12 lg:px-24 max-w-[1600px] mx-auto">
    <section class="py-24 md:py-32 grid grid-cols-1 md:grid-cols-12 gap-12 md:gap-16">
      <!-- Intro -->
      <div class="md:col-span-5 lg:col-span-4">
        <span class="brand-label block mb-6">Contact</span>
        <p class="text-lg md:text-xl text-text-muted leading-relaxed max-w-sm">
          歡迎來信討論您的住宅或空間設計需求。<br />
          For new project enquiries and collaborations, please use the form.
        </p>
      </div>

      <!-- Form -->
      <div class="md:col-span-7 lg:col-span-8 max-w-2xl">
        <form action={FORM_ACTION} method="POST" class="space-y-12">
          <input type="hidden" name="access_key" value={ACCESS_KEY} />
          <input
            type="hidden"
            name="subject"
            value="New enquiry from Minna Hsu Design website"
          />
          <input type="hidden" name="redirect" value={REDIRECT_URL} />
          {/* Honeypot: bots fill this hidden field; real users never see it */}
          <input
            type="checkbox"
            name="botcheck"
            class="hidden"
            style="display:none"
            tabindex="-1"
            autocomplete="off"
          />

          <div>
            <label for="name" class="brand-label block mb-4">Name</label>
            <input id="name" name="name" type="text" required class={inputClass} />
          </div>

          <div>
            <label for="email" class="brand-label block mb-4">Email</label>
            <input id="email" name="email" type="email" required class={inputClass} />
          </div>

          <div>
            <label for="phone" class="brand-label block mb-4">
              Phone
              <span class="normal-case tracking-normal text-text-muted/60">(optional)</span>
            </label>
            <input
              id="phone"
              name="phone"
              type="tel"
              inputmode="tel"
              pattern="[0-9+() -]{6,}"
              title="請輸入有效的電話號碼 / Please enter a valid phone number"
              class={inputClass}
            />
          </div>

          <div>
            <label for="message" class="brand-label block mb-4">Message</label>
            <textarea
              id="message"
              name="message"
              rows="5"
              required
              class={inputClass + " resize-none"}></textarea>
          </div>

          <button
            type="submit"
            class="brand-label border border-brand-sage px-10 py-4
                   hover:bg-brand-sage hover:text-base transition-colors duration-300"
          >
            Send Enquiry
          </button>
        </form>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
