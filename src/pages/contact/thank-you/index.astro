---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Footer from "../../../components/Footer.astro";
---
<BaseLayout
  title="Thank You | Minna Hsu Design"
  description="Thank you for your enquiry to Minna Hsu Design Studio."
>
  <main class="px-6 md:px-12 lg:px-24 max-w-[1600px] mx-auto">
    <section
      class="min-h-[60vh] flex flex-col items-center justify-center text-center py-24 md:py-32"
    >
      <span class="brand-label block mb-8">Thank You</span>

      <h1 class="text-3xl md:text-5xl font-sans font-light tracking-tight leading-tight mb-8">
        感謝您的來信
      </h1>

      <p class="text-base md:text-lg text-text-muted leading-relaxed max-w-md mb-12">
        我們已收到您的訊息，會盡快與您聯繫。<br />
        Thank you for reaching out. We&rsquo;ve received your message and will be
        in touch soon.
      </p>

      <a
        href="/"
        class="brand-label border border-brand-sage px-10 py-4
               hover:bg-brand-sage hover:text-base transition-colors duration-300"
      >
        Back to Home
      </a>
    </section>
  </main>
  <Footer />
</BaseLayout>
