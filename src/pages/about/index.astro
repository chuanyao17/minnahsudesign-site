---
import { Image } from "astro:assets";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Footer from "../../components/Footer.astro";
import portrait from "../../assets/Minna_selfie.jpg";

// Experience timeline sourced from the official portfolio PDF.
const experience = [
  { years: "2015–2019", role: "雲司國際設計有限公司", note: "主力住宅設計" },
  { years: "2019–2021", role: "New York School of Interior Design", note: "室內設計碩士 (MFA)" },
  { years: "2021–2024", role: "Lillian Wu Studio, New York", note: "飯店・餐廳・公設・住宅" },
  { years: "2025–", role: "米納許室內裝修設計有限公司", note: "創辦人" },
];
---
<BaseLayout
  title="About | Minna Hsu Design"
  description="Minna Hsu — interior designer. MFA, New York School of Interior Design; formerly Lillian Wu Studio, New York."
>
  <main class="px-6 md:px-12 lg:px-24 max-w-[1600px] mx-auto">
    <section class="py-24 md:py-32 grid grid-cols-1 md:grid-cols-12 gap-12 md:gap-16">
      <!-- Portrait -->
      <div class="md:col-span-5 lg:col-span-4">
        <Image
          src={portrait}
          alt="Minna Hsu"
          width={900}
          class="w-full h-auto"
          loading="eager"
        />
      </div>

      <!-- Bio -->
      <div class="md:col-span-7 lg:col-span-8 max-w-2xl">
        <span class="brand-label block mb-6">About</span>
        <h1 class="text-4xl md:text-5xl font-sans font-light tracking-tight mb-10">
          Minna Hsu
        </h1>

        <p class="text-lg md:text-xl text-text-muted leading-relaxed mb-4">
          理想的家，應兼具飯店的質感與家的溫度；而真正動人的空間，是在優雅與自在之間取得完美平衡。
        </p>
        <p class="text-base md:text-lg text-text-muted/80 leading-relaxed">
          An ideal home should combine the refined quality of a hotel with the
          warmth of a home. A truly captivating space achieves a perfect balance
          between elegance and comfort.
        </p>
      </div>
    </section>

    <!-- Experience -->
    <section class="pb-24 md:pb-32">
      <span class="brand-label block mb-6">Experience</span>
      <hr class="brand-rule mb-12" />
      <dl class="space-y-10">
        {
          experience.map((item) => (
            <div class="grid grid-cols-1 sm:grid-cols-12 gap-2 sm:gap-8 items-baseline">
              <dt class="sm:col-span-3 text-sm text-brand-sage-ink tracking-wide">
                {item.years}
              </dt>
              <dd class="sm:col-span-9">
                <span class="block text-lg md:text-xl font-light tracking-tight">
                  {item.role}
                </span>
                <span class="block text-sm text-text-muted mt-1">{item.note}</span>
              </dd>
            </div>
          ))
        }
      </dl>
    </section>
  </main>
  <Footer />
</BaseLayout>
