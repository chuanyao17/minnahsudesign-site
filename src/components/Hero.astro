---
import { Image } from 'astro:assets';
import coverImage from '../assets/projects/test-project-cover.webp';
---
<section class="relative w-full h-[80vh] min-h-[600px] flex items-end pb-16 sm:pb-24 px-6 md:px-12 lg:px-24">
  <div class="absolute inset-0 z-0">
    <Image 
      src={coverImage} 
      alt="Hero Cover" 
      class="w-full h-full object-cover"
      loading="eager"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-black/20"></div>
  </div>
  <div class="relative z-10 max-w-5xl">
    <h1 class="text-4xl sm:text-5xl md:text-7xl font-sans tracking-tight text-white leading-tight">
      Minimalism in Light.<br />
      <span class="text-white/80">Architecture & Interior.</span>
    </h1>
  </div>
</section>
