---
// Collapsible service-process timeline (native <details>, no JS).
// Hidden by default; revealed on click to keep the page editorial.
const steps = [
  { n: "01", title: "初次討論與量測", desc: "需求溝通、現場丈量、初步概念" },
  { n: "02", title: "平面方案與合約", desc: "平面圖討論、風格定案、簽訂設計約" },
  { n: "03", title: "細部設計與報價", desc: "3D 圖與施工圖製作、家具選樣、工程報價" },
  { n: "04", title: "施工監造與驗收", desc: "施工階段管理、家具進場、完工驗收交屋" },
];
---
<details class="process">
  <summary
    class="brand-label inline-flex items-center gap-3 cursor-pointer select-none border border-brand-sage px-8 py-4 hover:bg-brand-sage hover:text-base transition-colors duration-300"
  >
    設計服務流程
    <span class="plus text-lg leading-none transition-transform duration-300">+</span>
  </summary>

  <div class="process-content mt-16 md:mt-20">
    <ol class="relative grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-y-14 md:gap-x-8">
      <span
        class="hidden md:block absolute top-1.5 left-0 right-0 border-t border-brand-sage/50"
        aria-hidden="true"></span>
      {
        steps.map((s) => (
          <li class="relative text-center">
            <span
              class="block w-3 h-3 rounded-full bg-brand-sage mx-auto mb-8 ring-4 ring-base relative z-10"
              aria-hidden="true"
            />
            <span class="brand-label block mb-3">{s.n}</span>
            <h3 class="text-lg md:text-xl font-light tracking-tight mb-3">{s.title}</h3>
            <p class="text-sm text-text-muted leading-relaxed">{s.desc}</p>
          </li>
        ))
      }
    </ol>
  </div>
</details>

<style>
  .process > summary {
    list-style: none;
  }
  .process > summary::-webkit-details-marker {
    display: none;
  }
  /* Explicitly control the disclosure so it collapses reliably */
  .process > .process-content {
    display: none;
  }
  .process[open] > .process-content {
    display: block;
    animation: processReveal 0.45s ease both;
  }
  .process[open] > summary .plus {
    transform: rotate(45deg);
  }
  @keyframes processReveal {
    from {
      opacity: 0;
      transform: translateY(0.5rem);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
