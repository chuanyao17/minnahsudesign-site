---
const steps = [
  {
    title: '初次討論與量測',
    desc: '需求溝通、現場丈量、初步概念'
  },
  {
    title: '平面方案與合約',
    desc: '平面圖討論、風格定案、簽訂設計約'
  },
  {
    title: '細部設計與報價',
    desc: '3D圖與施工圖製作、家具選樣、工程報價'
  },
  {
    title: '施工監造與驗收',
    desc: '施工階段管理、家具進場、完工驗收交屋'
  }
];
---
<section class="py-16 md:py-24 px-6 md:px-12 lg:px-24 max-w-7xl mx-auto">
  <div class="mb-16 md:mb-20 flex justify-start md:justify-center">
    <h2 class="text-lg md:text-xl font-medium tracking-widest bg-[#798471] text-white px-6 py-2.5 shadow-sm">
      設計服務流程
    </h2>
  </div>

  <div class="relative">
    <!-- Mobile Vertical Line -->
    <div class="md:hidden absolute top-4 left-[11px] h-[calc(100%-3rem)] w-[2px] bg-[#e1e4dd]"></div>

    <div class="grid grid-cols-1 md:grid-cols-4 gap-12 md:gap-0 relative z-10">
      {
        steps.map((step, index) => (
          <div class="relative pl-12 md:pl-0 flex flex-col md:items-center text-left md:text-center">
            <!-- Mobile Dot -->
            <div class="md:hidden absolute left-0 top-[2px] w-[24px] h-[24px] rounded-full bg-[#aab1a5] ring-[6px] ring-white z-10"></div>
            
            <h3 class="text-lg font-medium text-text mb-2 md:mb-0 md:h-[40px] flex items-end justify-center">{step.title}</h3>
            
            <!-- Desktop Dot & Line Container -->
            <div class="hidden md:flex w-full h-[70px] items-center justify-center relative">
               <div class="absolute w-full h-[2px] bg-[#e1e4dd]"></div>
               <div class="w-[22px] h-[22px] rounded-full bg-[#aab1a5] z-10 relative ring-[8px] ring-white"></div>
            </div>
            
            <p class="text-sm text-text-muted leading-relaxed max-w-[240px] md:max-w-[90%] md:mx-auto mt-1 md:mt-0">{step.desc}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
