---
import Logo from "./Logo.astro";

// Dedicated pages per the .artifacts routing plan (Home is the logo).
const links = [
  { label: "Projects", href: "/projects/" },
  { label: "About", href: "/about/" },
  { label: "Contact", href: "/contact/" },
];
---
<header class="w-full bg-base/90 backdrop-blur-sm">
  <nav
    class="max-w-[1600px] mx-auto px-6 md:px-12 lg:px-24 py-6 flex items-center justify-between gap-6"
  >
    <Logo withName class="hover:text-brand-sage-ink transition-colors duration-300" />

    <ul class="flex items-center gap-8 md:gap-12">
      {
        links.map((link) => (
          <li>
            <a
              href={link.href}
              class="brand-label hover:text-brand-sage transition-colors duration-300"
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</header>
