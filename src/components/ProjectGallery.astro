---
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';

interface Props {
  gallery: ImageMetadata[];
}

const { gallery } = Astro.props;
---
{gallery.length > 0 && (
  <section class="mt-24 md:mt-32">
    {/* Pure-CSS masonry: images keep their natural ratio, packed into
        balanced columns with no row gaps. 1 column on mobile, 2 on desktop. */}
    <div class="columns-1 md:columns-2 gap-8 md:gap-12">
      {gallery.map((img, index) => (
        <div class="mb-8 md:mb-12 break-inside-avoid">
          <Image
            src={img}
            alt={`Gallery image ${index + 1}`}
            class="w-full h-auto bg-text-muted/10"
            loading="lazy"
          />
        </div>
      ))}
    </div>
  </section>
)}
