---
import Logo from "./Logo.astro";
---
<footer class="mt-24 md:mt-40 pb-20 md:pb-28">
  <div class="px-6 md:px-12 lg:px-24">
    <div class="max-w-[1600px] mx-auto text-center">
      <!-- Social -->
      <div class="flex justify-center mb-14 md:mb-16">
        <a
          href="https://www.instagram.com/minna.hsu_design/"
          target="_blank"
          rel="noopener noreferrer"
          class="brand-label hover:text-brand-sage transition-colors duration-300"
        >
          Instagram
        </a>
      </div>

      <!-- Mark (sized to harmonise with the wordmark below) -->
      <Logo class="justify-center mb-6 md:mb-8" markClass="h-10 sm:h-12 md:h-16 w-auto" />

      <!-- Wordmark sign-off (matches the sage mark) -->
      <h2
        class="font-sans font-light uppercase leading-tight tracking-[0.08em]
               text-3xl sm:text-4xl md:text-5xl text-brand-sage"
      >
        Minna Hsu Design Studio
      </h2>
    </div>
  </div>
</footer>
